# Only needed for stage 4 (brief generation). Stages 1-3 run without it.
ANTHROPIC_API_KEY=

# Optional — brief model. Default claude-opus-4-8 (sharpest prose, demo).
# For bulk/scheduled runs set claude-sonnet-4-6: the task is forced-schema +
# grounding-gated, so Sonnet matches quality at ~1/5 the cost.
BRIEF_MODEL=

# Optional — stage 3 homepage enrich. Without it, code stays on raw fetch
# (no behavior change). With it, SPA-shell homepages escalate to Apify JS render.
APIFY_TOKEN=

# Optional — local-only KKR product naming override (Task-3 Opt-2).
# Set to "local" to load config/kkr-products.local.ts (gitignored). Default: generic.
KKR_NAMING=

# [KKR-RIA] Optional — Supabase persistence. Without both, pipeline runs file-only.
# Use the SERVICE ROLE key (server-side only; RLS restricts writes to service_role).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# [KKR-RIA] Optional — agentic enrichment. Set to "1" to let an Opus tool-use
# agent decide per-firm which signals to fetch. Default: fixed deterministic fetch.
KKR_AGENTIC_ENRICH=
